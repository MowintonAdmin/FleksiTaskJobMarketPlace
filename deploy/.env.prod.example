BACKEND_HOST_PORT=8000
WEB_BIND_HOST=127.0.0.1
WEB_HOST_PORT=3000
ADMIN_BIND_HOST=127.0.0.1
ADMIN_HOST_PORT=3001
WEB_HOST=yourdomain.com
ADMIN_HOST=admin.yourdomain.com
API_HOST=api.yourdomain.com
WEB_VITE_API_BASE_URL=https://api.yourdomain.com
WEB_VITE_GOOGLE_CLIENT_ID=956971520016-5bfps8lm26gbufk85kn0pot5lgbo1toq.apps.googleusercontent.com
ADMIN_VITE_API_BASE_URL=https://api.yourdomain.com

# Backend CORS — must include every origin that calls the API.
# Add both the web and admin frontend URLs (use your real domain).
BACKEND_ALLOWED_ORIGINS=["https://yourdomain.com","https://admin.yourdomain.com"]

# Set these in backend/.env before first deploy if you want the backend
# to auto-create the initial admin account on startup.